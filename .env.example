# Earnings Intelligence Agent - environment configuration.
# Copy to .env and fill in the values. Missing required keys fail startup fast.
# See CLAUDE.md for the canonical list and PLAN.md section 7 for the security model.

# ---- Required: LLM ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Required: Market data ----
FINNHUB_API_KEY=your-finnhub-key

# ---- Required: Datastores ----
# Postgres includes the pgvector extension from Phase 3 onward.
DATABASE_URL=postgresql+psycopg://earnings:earnings@localhost:5432/earnings
REDIS_URL=redis://localhost:6379/0

# ---- Required: EDGAR ----
# SEC policy: User-Agent must include a real contact email. Format: "<name> <email>".
EDGAR_USER_AGENT=Paul Stanley Ganganapalli paulstanleyganganapalli@gmail.com
# Poll cadence for the EDGAR watcher (seconds).
EDGAR_POLL_INTERVAL_SECONDS=60

# ---- Required: Cost guard ----
# Hard daily cap on LLM spend. The client fails closed when exceeded.
MAX_DAILY_LLM_COST_USD=10.0

# ---- Required: Runtime ----
LOG_LEVEL=INFO
# dev | staging | prod | test
ENVIRONMENT=dev
# On-disk cache for LLM responses (cassettes for tests live elsewhere).
LLM_CACHE_DIR=./llm_cache

# ---- Optional: Delivery ----
# Leave unset to disable that delivery channel.
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SLACK_WEBHOOK_URL=

# ---- Optional: API gating ----
# Required in production: a comma-separated allowlist of API keys for /api/*.
API_KEYS=
